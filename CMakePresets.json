{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3, "minor": 22, "patch": 0
    },
    "configurePresets": [
        {
            "name":           "pc98",
            "displayName":    "NEC PC-9800 Series DOS/4G OpenWatcom V2",
            "generator":      "Ninja",
            "binaryDir":      "${sourceDir}/build-pc98",
            "toolchainFile":  "${sourceDir}/cmake/toolchains/openwatcom-dos4gw.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":   "Release",
                "NOCT_TARGET_DOS4G":  "ON",
                "NOCT_ENABLE_CLI":    "ON",
                "NOCT_ENABLE_JIT":    "ON",
                "NOCT_ENABLE_I18N":   "OFF",
                "NOCT_ENABLE_API":    "ON"
	    }
	}
    ],

    "buildPresets": [
        {
            "name": "pc98",
            "configurePreset": "pc98"
        }
    ]
}

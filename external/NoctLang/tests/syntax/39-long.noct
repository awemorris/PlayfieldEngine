func main() {
    print("123l + 321l = " + (123l + 321l));

    print("123L + 321L = " + (123L + 321L));
    print("100000000L + 1 = " + (100000000L + 1));
    print("1 + 100000000L = " + (1 + 100000000L));

    print("123L - 321L = " + (123L - 321L));
    print("100000000L - 3 = " + (100000000L - 3));
    print("3 - 100000000L = " + (3 - 100000000L));

    print("123L * 321L = " + (123L * 321L));
    print("100000000L * 3 = " + (100000000L * 3));
    print("3 * 100000000L = " + (3 * 100000000L));

    print("123L / 321L = " + (123L / 321L));
    print("100000000L / 3 = " + (100000000L / 3));
    print("3 / 100000000L = " + (3 / 100000000L));

    print("123L % 321L = " + (123L % 321L));
    print("100000000L % 3 = " + (100000000L % 3));
    print("3 % 100000000L = " + (3 % 100000000L));
}

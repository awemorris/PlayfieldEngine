func main() {
    var s = "ABC123あいう";

    print(s);
    print("charCount = " + String.charCount(s));
    print("substring(0, 0) = " + String.substring(s, 0, 0));
    print("substring(0, 1) = " + String.substring(s, 0, 1));
    print("substring(0, 2) = " + String.substring(s, 0, 2));
    print("substring(0, 3) = " + String.substring(s, 0, 3));
    print("substring(0, 4) = " + String.substring(s, 0, 4));
    print("substring(0, 5) = " + String.substring(s, 0, 5));
    print("substring(0, 6) = " + String.substring(s, 0, 6));
    print("substring(0, 7) = " + String.substring(s, 0, 7));
    print("substring(0, 8) = " + String.substring(s, 0, 8));
    print("substring(0, 9) = " + String.substring(s, 0, 9));
    print("substring(0, 10) = " + String.substring(s, 0, 10));
    print("substring(0, -1) = " + String.substring(s, 0, -1));

    print("substring(1, 0) = " + String.substring(s, 1, 0));
    print("substring(1, 1) = " + String.substring(s, 1, 1));
    print("substring(1, 2) = " + String.substring(s, 1, 2));
    print("substring(1, 3) = " + String.substring(s, 1, 3));
    print("substring(1, 4) = " + String.substring(s, 1, 4));
    print("substring(1, 5) = " + String.substring(s, 1, 5));
    print("substring(1, 6) = " + String.substring(s, 1, 6));
    print("substring(1, 7) = " + String.substring(s, 1, 7));
    print("substring(1, 8) = " + String.substring(s, 1, 8));
    print("substring(1, 9) = " + String.substring(s, 1, 9));
    print("substring(1, 10) = " + String.substring(s, 1, 10));
    print("substring(1, -1) = " + String.substring(s, 1, -1));

    print("substring(8, 0) = " + String.substring(s, 8, 0));
    print("substring(8, 1) = " + String.substring(s, 8, 1));

    print("substring(9, 0) = " + String.substring(s, 9, 0));
    print("substring(9, 1) = " + String.substring(s, 9, 1));
}

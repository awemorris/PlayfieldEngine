msgstr "Lenguaje de programación Noct\n"

msgid "Version %s\n"
msgstr "Versión %s\n"

msgid "Usage\n"
msgstr "Uso\n"

msgid "  noct <vm-options> <files>           ... run a program\n"
msgstr "  noct <vm-options> <files>           ... ejecutar un programa\n"

msgid "  noct --ansic <out-file> <in-files>  ... convert to a C source file\n"
msgstr "  noct --ansic <out-file> <in-files>  ... convertir en un archivo fuente en C\n"

msgid "  noct --elisp <out-file> <in-files>  ... convert to an Emacs Lisp source file\n"
msgstr "  noct --elisp <out-file> <in-files>  ... convertir en un archivo fuente Emacs Lisp\n"

msgid "  noct --scheme <out-file> <in-files> ... convert to an Scheme source file\n"
msgstr "  noct --scheme <out-file> <in-files> ... convertir en un archivo fuente Scheme\n"

msgid "  --disable-jit        ... disable JIT\n"
msgstr "  --disable-jit        ... desactivar JIT\n"

msgid "  --force-jit          ... equivalent to --jit-threshold=0\n"
msgstr "  --force-jit          ... equivalente a --jit-threshold=0\n"

msgid "  --jit-threshold=N    ... call-count threshold for compilation\n"
msgstr "  --jit-threshold=N    ... umbral de número de llamadas para la compilación\n"

msgid "  --optimize-level=N   ... optimize level (0/1)\n"
msgstr "  --optimize-level=N   ... nivel de optimización (0/1)\n"

msgid "  --gc-nursery-size=N  ... first GC space size in bytes\n"
msgstr "  --gc-nursery-size=N  ... tamaño del primer espacio GC en bytes\n"

msgid "  --gc-graduate-size=N ... second GC space size in bytes\n"
msgstr "  --gc-graduate-size=N ... tamaño del segundo espacio GC en bytes\n"

msgid "  --gc-tenure-size=N   ... final GC space size in bytes\n"
msgstr "  --gc-tenure-size=N   ... tamaño del espacio GC final en bytes\n"

msgid "  --gc-lop-threshold=N ... move objects larger than N-bytes to final GC space\n"
msgstr "  --gc-lop-threshold=N ... mover objetos mayores de N bytes al espacio GC final\n"

